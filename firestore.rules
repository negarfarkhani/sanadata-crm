rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Allow everything for now to facilitate seeding and prototype development
    // In a real app, these should be much stricter
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

{
  "entities": {
    "Integration": {
      "title": "Integration",
      "description": "Defines a connection between modules",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "sourceModule": { "type": "string" },
        "targetModule": { "type": "string" },
        "triggerEvent": { "type": "string" },
        "actions": { "type": "string" },
        "isActive": { "type": "boolean" },
        "priority": { "type": "number" }
      },
      "required": ["name", "slug", "sourceModule", "targetModule", "triggerEvent", "actions"]
    },
    "CRMContact": {
      "title": "CRM Contact",
      "description": "A contact in the CRM system",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string" },
        "stage": { "type": "string" }
      },
      "required": ["firstName", "email", "status", "stage"]
    },
    "AccountingEntry": {
      "title": "Accounting Entry",
      "description": "A financial entry",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "description": { "type": "string" },
        "totalDebit": { "type": "number" },
        "totalCredit": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["type", "description", "totalDebit", "totalCredit", "status"]
    }
  },
  "firestore": {
    "/integrations/{integrationId}": {
      "schema": "Integration",
      "description": "Collection of integration rules"
    },
    "/automation_logs/{logId}": {
      "schema": { "$ref": "AutomationLog" },
      "description": "Execution logs for automations"
    },
    "/crm_contacts/{contactId}": {
      "schema": "CRMContact",
      "description": "CRM contacts"
    },
    "/crm_deals/{dealId}": {
      "schema": { "$ref": "CRMDeal" },
      "description": "CRM deals"
    },
    "/crm_activities/{activityId}": {
      "schema": { "$ref": "CRMActivity" },
      "description": "CRM activities"
    },
    "/accounting_entries/{entryId}": {
      "schema": "AccountingEntry",
      "description": "Accounting entries"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "Transaction" },
      "description": "Financial transactions"
    }
  }
}
